# ─────────────────────────────────────────────────────────────────────
# RÈGLE 1 — JAMAIS de clé API payante côté client.
# Les clés des fournisseurs IA (Anthropic, Gemini, Mistral, OpenAI…) NE
# doivent JAMAIS avoir le préfixe `VITE_` : Vite les embarquerait dans le
# bundle navigateur. Elles restent côté serveur (variables Cloudflare sans
# préfixe) et ne transitent que par les proxys `functions/api/ai/*`.
#
# Liste alignée sur functions/env.d.ts (qui fait foi — audit F-13).
# En production, tout se configure dans le dashboard Cloudflare Pages
# (Settings → Environment variables) ; les bindings D1/KV se configurent
# dans Settings → Functions → Bindings (pas des variables d'env).
# ─────────────────────────────────────────────────────────────────────

# ── Clés des fournisseurs IA (server-side only — PAS de préfixe VITE_) ──
ANTHROPIC_API_KEY=your-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
MISTRAL_API_KEY=your-mistral-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
# Black Forest Labs (FLUX) — génération d'images, endpoint EU
BFL_API_KEY=your-bfl-api-key-here

# ── Google OAuth ──
# Client-side (identifiant public, OK en VITE_)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback
# Server-side only — do NOT prefix with VITE_
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# PR-0 tombstones (CDC Phase 1 D26/D29) : Gmail/Drive/Contacts/Sheets répondent
# 410 PAR DÉFAUT. Poser 'true' UNIQUEMENT en rollback d'urgence (Cloudflare :
# poser la var puis « Retry deployment »). Ne jamais laisser durablement.
# LEGACY_GOOGLE_CONNECTORS_ENABLED=true

# ── Google Workspace Add-on — Phase 0 HTTP (server-side) ──
# Kill switch : le spike répond 404 tant qu'il n'est pas explicitement activé.
WORKSPACE_ADDON_PHASE0_ENABLED=false
# Ressources dédiées du déploiement HTTP Marketplace, distinctes du client Web.
WORKSPACE_ADDON_PHASE0_OAUTH_CLIENT_ID=your-addon-client-id.apps.googleusercontent.com
WORKSPACE_ADDON_PHASE0_SERVICE_ACCOUNT_EMAIL=service-account@your-addon-project.iam.gserviceaccount.com
# Origine HTTPS exacte des endpoints, sans chemin (un slash final est accepté).
WORKSPACE_ADDON_PHASE0_BASE_URL=https://tryarty.com
# `rpc` = schéma RPC 2026 ; `legacy` = schéma alternate-runtime embarqué,
# uniquement pour trancher empiriquement GATE-HTTP-DRAFT-01.
WORKSPACE_ADDON_PHASE0_HOST_ACTION_SHAPE=rpc

# ── Contrôle d'accès (RÈGLE 2) ──
# Emails autorisés à utiliser les clés serveur (séparés par des virgules).
# ⚠️ Variable la plus critique de l'app : sans elle, le gate par plan
# (checkAllowedUser) n'a pas de VIP allowlist.
ALLOWED_EMAILS=owner@example.com
# Quotas journaliers server-key (défaut 50 par user si absent)
DAILY_QUOTA_PER_USER=50
# Optionnel : JSON par modèle, override DAILY_QUOTA_PER_USER
# DAILY_QUOTA_PER_MODEL={"claude-sonnet-5":100,"whisper-1":500,"default":500}

# ── Google Maps (server-side) — reverse geocoding /api/geo/reverse ──
GOOGLE_MAPS_API_KEY=your-maps-geocoding-key

# ── Recherche web (/api/search/web — Linkup par défaut, Brave en alternative) ──
SEARCH_PROVIDER=linkup
LINKUP_API_KEY=your-linkup-key
BRAVE_SEARCH_API_KEY=your-brave-key

# ── Facturation ──
# Lemon Squeezy (abonnements/licences) — secret HMAC des webhooks
LEMONSQUEEZY_WEBHOOK_SECRET=your-ls-webhook-secret
# Creem (crédits prépayés). Le product_id doit correspondre au même
# environnement que CREEM_API_KEY : valeur TEST en preview, valeur LIVE en prod.
CREEM_WEBHOOK_SECRET=your-creem-webhook-secret-hex
CREEM_API_KEY=creem_test_your-key
CREEM_CREDITS_10_PRODUCT_ID=prod_your-environment-product-id
# CREEM_API_BASE=https://test-api.creem.io   # optionnel, dérivé de la clé
# Réconciliation billing (Cron externe, owner-only)
RECONCILE_SECRET=your-random-reconcile-secret

# ── Essai par email (OTP) — TOUS serveur-only (RÈGLE 1) ──
RESEND_API_KEY=your-resend-key
EMAIL_FROM="Arty <noreply@tryarty.com>"
# Secret HMAC qui keye le hash des OTP. Aléatoire, ≥32 chars.
EMAIL_TRIAL_SECRET=change-me-random-32-chars-minimum
# Si présent, Turnstile est EXIGÉ sur request-otp (anti-bot). Fortement
# recommandé en production (audit F-10 : sans lui, seul le rate-limit D1
# borne l'envoi d'emails OTP).
TURNSTILE_SECRET_KEY=your-turnstile-secret

# ── WordPress (server-side only, owner-only via WORDPRESS_OWNER_EMAILS) ──
WP_URL=https://your-wordpress-site.com
WP_USERNAME=your-wp-login
WP_PASSWORD=your-wp-password
# Si vide, fallback sur ALLOWED_EMAILS
WORDPRESS_OWNER_EMAILS=owner@example.com

# ── Computer use (owner-only) ──
TUNNEL_URL=https://your-tunnel.your-domain.com
TUNNEL_SECRET=your-random-secret-token
COMPUTER_RELAY_ENABLED=false
COMPUTER_RELAY_OWNER_SUB=google-sub-of-owner

# ── Bindings Cloudflare (dashboard → Functions → Bindings, pas des env vars) ──
# DB  = base D1 (voir schema.sql pour le rollup des tables)
# KV  = namespace KV (legacy — premium cap migré en D1, quasi plus lu)
# WORKSPACE_ADDON_PHASE0_DB = base D1 dédiée au prototype Gmail HTTP ; ne
# jamais la faire pointer vers DB de production ou de bêta.

# NOTE : GOOGLE_VISION_API_KEY est de la config morte (OCR Vision retiré,
# BUG 14/15) — ne pas la configurer ; à retirer aussi du dashboard Cloudflare.
