# Anthropic API
VITE_ANTHROPIC_API_KEY=your-api-key-here

# Google OAuth (client-side)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback

# Google OAuth (server-side only — do NOT prefix with VITE_)
GOOGLE_CLIENT_SECRET=your-client-secret

# WordPress (server-side only)
WP_URL=https://facadespollet.fr
WP_USERNAME=your-wp-login
WP_PASSWORD=your-wp-password

# Cloudflare Tunnel + Computer Use (server-side only)
TUNNEL_URL=https://facades-pollet.your-domain.com
TUNNEL_SECRET=your-random-secret-token
