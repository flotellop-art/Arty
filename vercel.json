{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/wordpress/**": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/browser/**": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/computer/**": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
