{
  "name": "arty",
  "private": true,
  "version": "1.0.81",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p functions/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench:vision:workerd": "node scripts/bench-vision-workerd-memory.mjs",
    "addon:phase0:check": "node google-workspace-addon/phase0/render-manifest.mjs check-template",
    "no-casa:check": "node scripts/check-public-google-access.mjs",
    "no-casa:android-check": "node scripts/check-public-google-access.mjs --require-android-assets",
    "verify": "npm run addon:phase0:check && npm run no-casa:check && npm run typecheck && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/keyboard": "^8.0.2",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@streamparser/json-whatwg": "^0.0.22",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.11",
    "html2canvas": "^1.4.1",
    "i18next": "^24.2.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "idb": "^8.0.3",
    "jose": "^6.2.3",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.7.4",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.30.4",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260607.1",
    "@tailwindcss/typography": "^0.5.15",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.19.42",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.25.12",
    "jsdom": "^29.0.2",
    "miniflare": "^4.20260701.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "~5.6.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.4"
  }
}
